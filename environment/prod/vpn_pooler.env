## VPN Pooler
PI_API_URL=https://reverse_proxy:443
PI_VERIFY_SSL=false
PI_REQUIRE_OTP=true
DJANGO_SECRET_KEY=changeme
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://localhost:5443
DJANGO_LOG_LEVEL=INFO

## Session cookie lifetime — SECONDS. Upper bound; the actual per-session
## lifetime is pinned to the PI JWT's exp claim at login (see pooler/views.py
## _bind_session_to_jwt). Raise this only if PI issues longer-lived JWTs.
SESSION_COOKIE_AGE=43200

## Remote rsyslog forwarding for VPN Pooler.
## Set SYSLOG_ENABLED=true and SYSLOG_HOST to forward.
SYSLOG_ENABLED=false
SYSLOG_HOST=
SYSLOG_PORT=514
SYSLOG_PROTO=udp
SYSLOG_FACILITY=local0
SYSLOG_TAG=pi-vpn-pooler
SYSLOG_LEVEL=INFO
