## Custom Captive Portal (TOTP self-enrollment)
PI_API_URL=https://reverse_proxy:443
PI_VERIFY_SSL=false
PI_REALM=defrealm
OTPAUTH_ISSUER=privacyIDEA
OTPAUTH_LABEL_ATTR=username
TOKEN_SERIAL_PREFIX=
TOKEN_SERIAL_SUFFIX=username
DJANGO_SECRET_KEY=changeme
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://localhost:6443
DJANGO_LOG_LEVEL=INFO

## Session cookie lifetime — SECONDS. Upper bound; the actual per-session
## lifetime is pinned to the PI JWT's exp claim at login (see captive/views.py
## _bind_session_to_jwt). Raise this only if PI issues longer-lived JWTs.
SESSION_COOKIE_AGE=43200

## mTLS identity via upstream nginx (opt-in).
MTLS_ENABLED=false
MTLS_USER_HEADER=HTTP_X_SSL_USER
MTLS_VERIFY_HEADER=HTTP_X_SSL_VERIFY
MTLS_REQUIRED_VERIFY_VALUE=SUCCESS

## Remote rsyslog forwarding for Captive Portal.
## Set SYSLOG_ENABLED=true and SYSLOG_HOST to forward.
SYSLOG_ENABLED=false
SYSLOG_HOST=
SYSLOG_PORT=514
SYSLOG_PROTO=udp
SYSLOG_FACILITY=local2
SYSLOG_TAG=pi-custom-captive
SYSLOG_LEVEL=INFO
