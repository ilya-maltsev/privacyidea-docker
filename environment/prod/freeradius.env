## FreeRADIUS
RADIUS_PI_HOST=https://reverse_proxy
RADIUS_PI_REALM=
RADIUS_PI_RESCONF=
RADIUS_PI_SSLCHECK=false
RADIUS_DEBUG=false
RADIUS_PI_TIMEOUT=10

## [Mapping user] injection. Comma-separated pi_key=Radius-Attribute pairs.
## Each pair maps detail.user.<pi_key> from privacyIDEA into the named RADIUS
## reply attribute. Leave empty to disable.
## Example: RADIUS_PI_MAPPING_USER=vpn_ip=Framed-IP-Address,group=Class
RADIUS_PI_MAPPING_USER=

## Remote rsyslog forwarding for FreeRADIUS plugin.
## Leave RADIUS_SYSLOG_HOST empty to use the local syslogd inside the container.
RADIUS_SYSLOG=true
RADIUS_SYSLOG_HOST=
RADIUS_SYSLOG_PORT=514
RADIUS_SYSLOG_PROTO=udp
RADIUS_SYSLOG_FACILITY=auth
RADIUS_SYSLOG_TAG=privacyidea-radius
RADIUS_SYSLOG_LEVEL=INFO
