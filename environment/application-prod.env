ENVIRONMENT="environment/application-prod.env"

## PrivacyIDEA
PI_VERSION=3.13
PI_ADMIN=admin
PI_ADMIN_PASS=admin
PI_ADDRESS=0.0.0.0 
PI_PORT=8080
PI_LOGLEVEL=INFO
PI_PEPPER=changeMe
PI_SECRET=changeMe
#PI_ENCKEY=9KraeeWGbIANYFHS+4L4YY2uRE/xP3pdeMZ5hrHYagmFo5vbYxNcruv4mh2P/pX6xUp+Px/AKLPANzi1s3N4O2vWEC7a2yzk3o4LcWKupFAbW/Jl1kM16EvCyCQ9hpKe
SUPERUSER_REALM="admin,helpdesk"
SQLALCHEMY_ENGINE_OPTIONS=False
#PI_AUDIT_NO_SIGN=False
#PI_AUDIT_SQL_URI=
PI_AUDIT_KEY_PRIVATE="/privacyidea/etc/persistent/private.pem"
PI_AUDIT_KEY_PUBLIC="/privacyidea/etc/persistent/public.pem"

## uncomment two lines below for new UI preview
#PI_STATIC_FOLDER="static_new/"
#PI_TEMPLATE_FOLDER="static_new/dist/privacyidea-webui/browser/"


## DB connection parameters
DB_HOST=db
DB_PORT=5432
DB_NAME=pi
DB_USER=pi
DB_PASSWORD=superSecret
DB_API=postgresql+psycopg2

## reverse proxy port
PROXY_PORT=8443
PROXY_SERVERNAME=localhost

## Prod TLS: host-side paths to the certificate and key files.
## These paths are bind-mounted into the reverse_proxy container.
## Leave unset to fall back to the dev self-signed pair at ./templates/pi.pem + pi.key.
## Example:
##   NGINX_TLS_CERT_PATH=/etc/ssl/private/privacyidea.pem
##   NGINX_TLS_KEY_PATH=/etc/ssl/private/privacyidea.key
NGINX_TLS_CERT_PATH=
NGINX_TLS_KEY_PATH=

## Remote rsyslog forwarding for privacyIDEA application.
## Set PI_SYSLOG_ENABLED=true and PI_SYSLOG_HOST to forward.
## Default transport: udp. Default level: INFO.
PI_SYSLOG_ENABLED=false
PI_SYSLOG_HOST=
PI_SYSLOG_PORT=514
PI_SYSLOG_PROTO=udp
PI_SYSLOG_FACILITY=local1
PI_SYSLOG_TAG=privacyidea
PI_SYSLOG_LEVEL=INFO

## External RADIUS ports
RADIUS_PORT=1812
RADIUS_PORT_INC=1813

## Remote rsyslog forwarding for FreeRADIUS plugin.
## Leave RADIUS_SYSLOG_HOST empty to use the local syslogd inside the container.
## Default transport: udp. Default level: INFO. Facility: auth | local0..local7.
RADIUS_SYSLOG=true
RADIUS_SYSLOG_HOST=
RADIUS_SYSLOG_PORT=514
RADIUS_SYSLOG_PROTO=udp
RADIUS_SYSLOG_FACILITY=auth
RADIUS_SYSLOG_TAG=privacyidea-radius
RADIUS_SYSLOG_LEVEL=INFO

## External LDAP port
LDAP_PORT=1389

## VPN Pooler
VPN_POOLER_PI_API_URL=https://reverse_proxy:443
VPN_POOLER_PI_VERIFY_SSL=false
VPN_POOLER_DJANGO_SECRET_KEY=changeme
VPN_POOLER_DJANGO_DEBUG=false
VPN_POOLER_DJANGO_ALLOWED_HOSTS=*
VPN_POOLER_CSRF_TRUSTED_ORIGINS=https://localhost:5443
VPN_POOLER_PORT=5443

## Remote rsyslog forwarding for VPN Pooler.
## Set VPN_POOLER_SYSLOG_ENABLED=true and VPN_POOLER_SYSLOG_HOST to forward.
## Default transport: udp. Default level: INFO.
VPN_POOLER_SYSLOG_ENABLED=false
VPN_POOLER_SYSLOG_HOST=
VPN_POOLER_SYSLOG_PORT=514
VPN_POOLER_SYSLOG_PROTO=udp
VPN_POOLER_SYSLOG_FACILITY=local0
VPN_POOLER_SYSLOG_TAG=pi-vpn-pooler
VPN_POOLER_SYSLOG_LEVEL=INFO

## Custom Captive Portal (TOTP self-enrollment)
CAPTIVE_PI_API_URL=https://reverse_proxy:443
CAPTIVE_PI_VERIFY_SSL=false
CAPTIVE_PI_REALM=defrealm
CAPTIVE_OTPAUTH_ISSUER=privacyIDEA
CAPTIVE_OTPAUTH_LABEL_ATTR=username
CAPTIVE_TOKEN_SERIAL_PREFIX=
CAPTIVE_TOKEN_SERIAL_SUFFIX=username
CAPTIVE_DJANGO_SECRET_KEY=changeme
CAPTIVE_DJANGO_DEBUG=false
CAPTIVE_DJANGO_ALLOWED_HOSTS=*
CAPTIVE_CSRF_TRUSTED_ORIGINS=https://localhost:6443
CAPTIVE_DJANGO_LOG_LEVEL=INFO
CAPTIVE_PORT=6443

## mTLS identity via upstream nginx (opt-in). When enabled, the portal trusts
## X-SSL-User and X-SSL-Verify headers set by nginx after client-cert verify.
## See pi-custom-captive/templates/nginx-mtls.*.example.conf for the nginx side.
CAPTIVE_MTLS_ENABLED=false
CAPTIVE_MTLS_USER_HEADER=HTTP_X_SSL_USER
CAPTIVE_MTLS_VERIFY_HEADER=HTTP_X_SSL_VERIFY
CAPTIVE_MTLS_REQUIRED_VERIFY_VALUE=SUCCESS

## Remote rsyslog forwarding for Captive Portal.
## Set CAPTIVE_SYSLOG_ENABLED=true and CAPTIVE_SYSLOG_HOST to forward.
CAPTIVE_SYSLOG_ENABLED=false
CAPTIVE_SYSLOG_HOST=
CAPTIVE_SYSLOG_PORT=514
CAPTIVE_SYSLOG_PROTO=udp
CAPTIVE_SYSLOG_FACILITY=local2
CAPTIVE_SYSLOG_TAG=pi-custom-captive
CAPTIVE_SYSLOG_LEVEL=INFO
