## Custom Captive Portal (dev)
PI_API_URL=https://reverse_proxy:443
PI_VERIFY_SSL=false
PI_REALM=exampleorg
OTPAUTH_ISSUER=VPN-GATE1
OTPAUTH_LABEL_ATTR=username
TOKEN_SERIAL_PREFIX=VPN-GATE1
TOKEN_SERIAL_SUFFIX=username
DJANGO_SECRET_KEY=u28PIXb85ed9jkolpUbrJVEwRthXUVJh5pGAYlZaegbwoyvghf
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://localhost:6443
DJANGO_LOG_LEVEL=DEBUG

## mTLS identity via upstream nginx (opt-in).
MTLS_ENABLED=false
MTLS_USER_HEADER=HTTP_X_SSL_USER
MTLS_VERIFY_HEADER=HTTP_X_SSL_VERIFY
MTLS_REQUIRED_VERIFY_VALUE=SUCCESS

## Remote rsyslog — points to rsyslog container in fullstack profile.
SYSLOG_ENABLED=true
SYSLOG_HOST=rsyslog
SYSLOG_PORT=514
SYSLOG_PROTO=udp
SYSLOG_FACILITY=local2
SYSLOG_TAG=pi-custom-captive
SYSLOG_LEVEL=DEBUG
