## VPN Pooler (dev)
PI_API_URL=https://reverse_proxy:443
PI_VERIFY_SSL=false
PI_REQUIRE_OTP=false
DJANGO_SECRET_KEY=BTH2ny1Szb2c0pJC5VEErW237AtXskjFRqWWMypluBGRd5NzCH
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://localhost:5444
DJANGO_LOG_LEVEL=INFO

## Session cookie lifetime — SECONDS. Upper bound; actual session ends when
## the PI JWT expires.
SESSION_COOKIE_AGE=43200

## Remote rsyslog — points to rsyslog container in fullstack profile.
SYSLOG_ENABLED=true
SYSLOG_HOST=rsyslog
SYSLOG_PORT=514
SYSLOG_PROTO=udp
SYSLOG_FACILITY=local0
SYSLOG_TAG=pi-vpn-pooler
SYSLOG_LEVEL=DEBUG
