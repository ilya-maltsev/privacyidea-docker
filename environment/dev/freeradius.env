## FreeRADIUS (dev)
RADIUS_PI_HOST=https://reverse_proxy
RADIUS_PI_REALM=
RADIUS_PI_RESCONF=
RADIUS_PI_SSLCHECK=false
RADIUS_DEBUG=false
RADIUS_PI_TIMEOUT=10

## Remote rsyslog — points to rsyslog container in fullstack profile.
RADIUS_SYSLOG=true
RADIUS_SYSLOG_HOST=rsyslog
RADIUS_SYSLOG_PORT=514
RADIUS_SYSLOG_PROTO=udp
RADIUS_SYSLOG_FACILITY=auth
RADIUS_SYSLOG_TAG=privacyidea-radius
RADIUS_SYSLOG_LEVEL=DEBUG
