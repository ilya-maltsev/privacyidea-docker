## Compose-level variables for dev environment.

## Reverse proxy
PROXY_PORT=8444
PROXY_SERVERNAME=localhost

## No custom TLS in dev — uses self-signed pair.
NGINX_TLS_CERT_PATH=
NGINX_TLS_KEY_PATH=

## External ports (offset from prod to allow parallel stacks)
PI_PORT=8081
RADIUS_PORT=1814
RADIUS_PORT_INC=1815
LDAP_PORT=1398
VPN_POOLER_PORT=5444
CAPTIVE_PORT=6443
